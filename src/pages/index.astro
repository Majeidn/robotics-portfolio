---
// 1. Import your layout (make sure the path matches where you saved it) 
import MainLayout from '../layouts/Layout.astro';

// 2. Fetch all the Markdown projects from your content folder 
// @ts-ignore
const projects = Object.values(import.meta.glob('./projects/*.md', { eager: true })) as any[];
---

<MainLayout>
  <header class="hero">
    <h1>Hi, I'm Mark.</h1>
    <p>I build robots and the software that makes them move.</p>
  </header>

  <main class="portfolio-container">
    <h2>My Projects</h2>
    
    <div class="project-grid">
		{projects.map((project) => (
		  /* 1. The whole card is now the link */
		  <a href={project.url} class="project-card">
			
			<img src={project.frontmatter.image} alt={project.frontmatter.title} class="thumbnail" />
			
			<div class="card-content">
			  <h3>{project.frontmatter.title}</h3>
			  <p>{project.frontmatter.summary}</p>
			  
			  <div class="tech-stack">
				{project.frontmatter.tech.map((tool) => (
				  <span class="tech-badge">{tool}</span>
				))}
			  </div>
			  
			  /* 2. The old button is now a span */
			  <span class="btn-learn-more">Learn More &rarr;</span>
			</div>
		  </a>
		))}
	</div>
  </main>
</MainLayout>

<style>
  /* --- The Dark Mode Engineering Aesthetic --- */
  
  :root {
    --bg-dark: #121212;
    --card-dark: #1E1E1E;
    --accent: #3b82f6; /* A clean, technical blue */
    --text-main: #f3f4f6;
    --text-muted: #9ca3af;
  }

  /* Note: You might want to move these body styles to your MainLayout.astro later */
  body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
    padding: 0;
  }

  .hero {
    text-align: center;
    padding: 6rem 1rem 4rem;
    border-bottom: 1px solid #333;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  /* The Grid Layout */
  .project-grid {
    display: grid;
    /* This automatically creates columns that fit the screen size */
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  /* The Card Design */
  .project-card {
    display: block;             /* Ensures the link fills the whole grid space */
    text-decoration: none;      /* Removes the blue link underline */
    color: inherit;             /* Keeps your text colors exactly how they were */
    background-color: var(--card-dark);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid #333;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    border-color: var(--accent);
  }

  .thumbnail {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-bottom: 1px solid #333;
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-content h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .card-content p {
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  /* Small badges for C++, ROS, etc. */
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tech-badge {
    background-color: #2d2d2d;
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .btn-learn-more {
    display: inline-block;
    background-color: var(--accent);
    color: white;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: background-color 0.2s ease;
  }

  .btn-learn-more:hover {
    background-color: #2563eb;
  }
</style>