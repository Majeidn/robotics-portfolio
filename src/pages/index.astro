---
// 1. Import your layout (make sure the path matches where you saved it) 
import MainLayout from '../layouts/Layout.astro';

// 2. Fetch all the Markdown projects from your content folder 
// @ts-ignore
const projects = Object.values(import.meta.glob('./projects/*.md', { eager: true })) as any[];
---

<MainLayout>
	<header class="hero">
		<div class="hero-left">
		  <img src="/robotics-portfolio/headshot.jpg" alt="Mark - Robotics Engineer" class="profile-pic" />
		  
		  <div class="bio-text">
			<h1>Hi, I'm Mark.</h1>
			<h2>Robotics & Software Engineer</h2>
			<p>
			  I build robots and the software that makes them move. 
			  Currently studying [Your Major] at [Your University].
			</p>
			
			<div class="hero-links">
			  <a href="mailto:mkheyfets@wpi.edu" class="btn-primary">Email Me</a>
			  <a href="/resume.pdf" target="_blank" class="btn-secondary">View Resume</a>
			</div>
		  </div>
		</div>
	  
		<div class="hero-right">
		  <img src="/robotics-portfolio/wheel.svg" alt="Adaptation" class="adaptation-wheel" />
		</div>
	</header>

  <main class="portfolio-container">
    <h2>My Projects</h2>
    
    <div class="project-grid">
		{projects.map((project) => (
		  /* 1. The whole card is now the link */
		  <a href={project.url} class="project-card">
			
			<img src={project.frontmatter.image} alt={project.frontmatter.title} class="thumbnail" />
			
			<div class="card-content">
			  <h3>{project.frontmatter.title}</h3>
			  <p>{project.frontmatter.summary}</p>
			  
			  <div class="tech-stack">
				{project.frontmatter.tech.map((tool) => (
				  <span class="tech-badge">{tool}</span>
				))}
			  </div>
			  
			  <span class="btn-learn-more">Learn More &rarr;</span>
			</div>
		  </a>
		))}
	</div>
  </main>
</MainLayout>

<style>
  /* --- The Dark Mode Engineering Aesthetic --- */
  
  :root {
    --bg-dark: #121212;
    --card-dark: #1E1E1E;
    --accent: #3b82f6; /* A clean, technical blue */
    --text-main: #f3f4f6;
    --text-muted: #9ca3af;
  }

  /* Note: You might want to move these body styles to your MainLayout.astro later */
  body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
    padding: 0;
  }

  .hero, .portfolio-container {
    max-width: 3000px; /* Keeps it contained on massive ultra-wide monitors */
    width: 95%; /* Pushes everything out toward the edges of the screen */
    margin: 0 auto;
  }

	.hero {
    display: flex;
    justify-content: space-between; /* This strictly forces the left and right sections apart */
    align-items: center;
    padding: 6rem 0 4rem 0;
    border-bottom: 1px solid #333;
  }

  .hero-left {
    display: flex;
    gap: 3rem; 
    align-items: center;
  }

  .profile-pic {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent);
    flex-shrink: 0; /* <--- This stops Flexbox from squishing it into an oval! */
  }

  .bio-text {
    text-align: left; 
  }

  .bio-text h1 {
    font-size: 3rem;
    margin: 0 0 0.5rem 0;
  }

  .bio-text h2 {
    font-size: 1.25rem;
    color: var(--accent);
    margin: 0 0 1rem 0;
    font-weight: 500;
  }

  .bio-text p {
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 500px;
    margin-bottom: 1.5rem;
  }

  /* Contact Buttons */
  .hero-links {
    display: flex;
    gap: 1rem;
  }

  .btn-primary, .btn-secondary {
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background-color: #2563eb;
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--text-main);
    border: 1px solid #333;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
  }

  /*  The Mahoraga Wheel Easter Egg  */
  .hero-right {
    opacity: 0.2; /* Keeps it subtle so it doesn't overpower the page */
	align-self: flex-start; 
    margin-top: -4rem;
  }

  .adaptation-wheel {
    width: 120px;
    height: 120px;
    /* This creates a slow, continuous rotation. We can tie this to Astro View Transitions later! */
    animation: spin 12s linear infinite; 
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Mobile Responsiveness */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      gap: 3rem;
    }
    .hero-left {
      flex-direction: column;
    }
    .hero-links {
      justify-content: center;
    }
  }

  /* The Grid Layout */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));; 
    gap: 2.5rem;
    margin-top: 2rem;
  }

  /* The Card Design */
  .project-card {
	max-width: 360px;
    width: 100%;
	margin: 0 auto;
    display: block;             /* Ensures the link fills the whole grid space */
    text-decoration: none;      /* Removes the blue link underline */
    color: inherit;             /* Keeps the text colors exactly how they were */
    background-color: var(--card-dark);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid #333;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    border-color: var(--accent);
  }

  .thumbnail {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-bottom: 1px solid #333;
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-content h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .card-content p {
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  /* Small badges for C++, ROS, etc. */
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tech-badge {
    background-color: #2d2d2d;
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .btn-learn-more {
    display: inline-block;
    background-color: var(--accent);
    color: white;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: background-color 0.2s ease;
  }

  .btn-learn-more:hover {
    background-color: #2563eb;
  }
</style>