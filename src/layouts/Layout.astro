---
import { ClientRouter } from 'astro:transitions';

const { frontmatter, title } = Astro.props;

const pageTitle = frontmatter?.title || title || "Mark's Robotics Portfolio";
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{pageTitle}</title>

		<ClientRouter />
    </head>
    <body>
		<div class="global-wheel-container">
			<img 
			  src="/robotics-portfolio/wheel.svg" 
			  alt="Adaptation" 
			  class="global-wheel" 
			  transition:persist="mahoraga-wheel" 
			/>
		</div>

        {/* This checks if the page is a Markdown project. If it is, it renders the button. */}
        {frontmatter && (
          <nav class="top-nav">
            <a href="https://majeidn.github.io/robotics-portfolio/" class="btn-back">&larr; Back to Portfolio</a>
          </nav>
        )}
      
        {/* I use a conditional class to only restrict width on project pages */}
        <div class={frontmatter ? "project-wrapper" : ""}>
          <slot />
        </div>

        <script>
			document.addEventListener('astro:before-preparation', () => {
			  const wheel = document.querySelector('.global-wheel');
			  if (wheel) wheel.classList.add('spinning');
			});
			
			document.addEventListener('astro:page-load', () => {
			  setTimeout(() => {
				const wheel = document.querySelector('.global-wheel');
				if (wheel) wheel.classList.remove('spinning');
			  }, 400); 
			});
		</script>
      </body>
</html>

<style is:global>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }

    /*  Navigation Styles  */
    .top-nav {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 2rem 0 2rem; 
    }

    .btn-back {
      display: inline-block;
      color: #9ca3af; 
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      background-color: #1e1e1e;
      border: 1px solid #333;
      transition: all 0.2s ease;
    }

    .btn-back:hover {
      color: #fff;
      background-color: #2d2d2d;
      border-color: #3b82f6; 
    }
    
    /* Base dark theme for the whole site */
    body {
      background-color: #121212;
      color: #f3f4f6;
      font-family: system-ui, -apple-system, sans-serif;
      margin: 0;
      padding: 0;
    }

    /* Centers and resizes the video */
    .video-wrapper {
      width: 100%;
      max-width: 800px;
      margin: 2rem auto;
    }

    .video-wrapper iframe {
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      border: 1px solid #333;
    }

    /* This replaces the old 'main' rule and ONLY targets Markdown pages */
    .project-wrapper {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem;
      line-height: 1.6;
    }

  .global-wheel-container {
    position: absolute;
    top: 2rem;
    right: 5%; 
    opacity: 0.2;
    z-index: 100;
    pointer-events: none; 
  }

  .global-wheel {
    width: 100px;
    height: 100px;
    animation: spin 3s linear infinite; 
    animation-play-state: paused;
  }

  /* When the page transitions, release the brake! */
  .global-wheel.spinning {
    animation-play-state: running;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 768px) {
    .global-wheel-container {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      top: 1rem;
    }
  }
</style>